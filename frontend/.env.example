# 🌿 AgriFuture AI Environment Variables

# 🌐 Weather API Configuration
# Get your free API key from: https://openweathermap.org/api
REACT_APP_WEATHER_API_KEY=your_openweathermap_api_key_here

# 🌐 API Configuration
REACT_APP_API_URL=http://localhost:9000/api/v1
REACT_APP_CAPACITOR_HOST=192.168.1.2
# Or set a full mobile URL instead:
# REACT_APP_CAPACITOR_API_URL=http://192.168.1.2:8000/api/v1

# 🌐 Firebase Configuration (if using)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# 🌐 Google Sign-In Configuration
REACT_APP_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
REACT_APP_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_IDS=your_google_web_client_id.apps.googleusercontent.com,your_google_android_client_id.apps.googleusercontent.com

# 🌐 Application Configuration
REACT_APP_NAME=AgriFuture AI
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Smart Farming Assistant
