@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Sora:wght@400;600;700&display=swap');

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --green-dark: #1a5c2a;
  --green-mid: #2d7a3a;
  --green-light: #4caf50;
  --green-soft: #e8f5e9;
  --green-accent: #66bb6a;
  --amber: #f59e0b;
  --amber-soft: #fffbeb;
  --blue: #3b82f6;
  --blue-soft: #eff6ff;
  --purple: #8b5cf6;
  --purple-soft: #f5f3ff;
  --red-soft: #fff1f0;
  --red: #ef4444;
  --text-primary: #1a2e1c;
  --text-secondary: #5a7a5e;
  --text-muted: #94a3a8;
  --border: #e2ebe3;
  --bg: #f5f7f5;
  --white: #ffffff;
  --card-shadow: 0 1px 4px rgba(0, 0, 0, 0.06), 0 4px 16px rgba(0, 0, 0, 0.04);
  --card-shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.10), 0 8px 24px rgba(0, 0, 0, 0.06);
  --font-display: 'Sora', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --radius: 14px;
  --radius-sm: 10px;
}

body {
  background: var(--bg);
  font-family: var(--font-body);
  color: var(--text-primary);
}

/* ──────────────────────────────────────────
   APP WRAPPER
────────────────────────────────────────── */
.app {
  max-width: 430px;
  margin: 0 auto;
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  padding-bottom: 90px;
}

.scroll-content {
  overflow-y: auto;
}

/* ──────────────────────────────────────────
   TOP NAV
────────────────────────────────────────── */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px 10px;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-brand {
  display: flex;
  flex-direction: column;
}

.nav-brand-name {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--green-dark);
  letter-spacing: -0.3px;
}

.nav-brand-sub {
  font-size: 10px;
  color: var(--text-muted);
  font-weight: 400;
  letter-spacing: 0.2px;
}

.hamburger {
  width: 36px;
  height: 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  cursor: pointer;
}

.hamburger span {
  display: block;
  height: 2px;
  background: var(--text-secondary);
  border-radius: 2px;
  transition: 0.2s;
}

.hamburger span:nth-child(1) { width: 20px; }
.hamburger span:nth-child(2) { width: 14px; }

.bell-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--green-soft);
  border: none;
  cursor: pointer;
  position: relative;
}

.bell-dot {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--red);
  border: 1.5px solid var(--white);
}

/* ──────────────────────────────────────────
   HEADER SECTION
────────────────────────────────────────── */
.header-section {
  padding: 20px 20px 0;
}

.greeting-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 4px;
}

.greeting {
  font-size: 13px;
  font-weight: 500;
  color: var(--green-mid);
  display: flex;
  align-items: center;
  gap: 5px;
}

.username {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
  letter-spacing: -0.4px;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
}

.meta-item svg {
  opacity: 0.6;
}

/* ──────────────────────────────────────────
   WEATHER CARD
────────────────────────────────────────── */
.weather-card {
  margin: 16px 20px 0;
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 60%, #3d9e50 100%);
  border-radius: var(--radius);
  padding: 20px;
  color: white;
  position: relative;
  overflow: hidden;
}

.weather-card::before {
  content: '';
  position: absolute;
  top: -40px;
  right: -40px;
  width: 150px;
  height: 150px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.weather-card::after {
  content: '';
  position: absolute;
  bottom: -30px;
  right: 20px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.weather-icon {
  font-size: 36px;
}

.weather-temp {
  font-family: var(--font-display);
  font-size: 40px;
  font-weight: 700;
  letter-spacing: -2px;
  line-height: 1;
}

.weather-desc {
  font-size: 13px;
  opacity: 0.85;
  margin-top: 2px;
  font-weight: 400;
}

.weather-stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  margin-bottom: 14px;
}

.weather-stat {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 10px;
  padding: 10px 8px;
  text-align: center;
  backdrop-filter: blur(4px);
}

.weather-stat-val {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 600;
}

.weather-stat-lbl {
  font-size: 10px;
  opacity: 0.75;
  margin-top: 2px;
  font-weight: 400;
}

.weather-advisory {
  background: rgba(255, 255, 255, 0.13);
  border-radius: 10px;
  padding: 10px 12px;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  backdrop-filter: blur(4px);
}

.advisory-icon {
  font-size: 14px;
  margin-top: 1px;
  flex-shrink: 0;
}

.advisory-title {
  font-size: 11px;
  font-weight: 600;
  opacity: 0.95;
  margin-bottom: 2px;
  letter-spacing: 0.2px;
}

.advisory-text {
  font-size: 11px;
  opacity: 0.8;
  line-height: 1.4;
  font-weight: 400;
}

/* ──────────────────────────────────────────
   STATS ROW
────────────────────────────────────────── */
.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin: 14px 20px 0;
}

.stat-card {
  background: var(--white);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  box-shadow: var(--card-shadow);
  display: flex;
  align-items: center;
  gap: 12px;
  transition: transform 0.18s, box-shadow 0.18s;
  cursor: pointer;
}

.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--card-shadow-hover);
}

.stat-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.stat-icon.green  { background: var(--green-soft); }
.stat-icon.blue   { background: var(--blue-soft); }
.stat-icon.amber  { background: var(--amber-soft); }
.stat-icon.purple { background: var(--purple-soft); }

.stat-val {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.4px;
}

.stat-lbl {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
  margin-top: 1px;
}

.stat-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 20px;
  margin-top: 2px;
}

.stat-badge.amber { background: var(--amber-soft); color: var(--amber); }
.stat-badge.green { background: var(--green-soft); color: var(--green-dark); }

/* ──────────────────────────────────────────
   SECTION TITLE
────────────────────────────────────────── */
.section-title {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  color: var(--green-dark);
  margin-bottom: 12px;
  letter-spacing: -0.2px;
}

/* ──────────────────────────────────────────
   FARM INSIGHTS
────────────────────────────────────────── */
.insights-section {
  padding: 18px 20px 0;
}

.insights-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.insight-card {
  background: var(--white);
  border-radius: var(--radius-sm);
  padding: 16px;
  box-shadow: var(--card-shadow);
  text-align: center;
  transition: transform 0.18s, box-shadow 0.18s;
  cursor: pointer;
}

.insight-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--card-shadow-hover);
}

.insight-icon {
  font-size: 24px;
  margin-bottom: 6px;
}

.insight-lbl {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
  margin-bottom: 4px;
}

.insight-val {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5px;
}

/* ──────────────────────────────────────────
   QUICK SERVICES
────────────────────────────────────────── */
.services-section {
  padding: 18px 20px 0;
}

.services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.service-card {
  background: var(--white);
  border-radius: var(--radius-sm);
  padding: 16px;
  box-shadow: var(--card-shadow);
  cursor: pointer;
  transition: transform 0.18s, box-shadow 0.18s;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.service-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--card-shadow-hover);
}

.service-icon-wrap {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.service-icon-wrap.green  { background: #dcfce7; }
.service-icon-wrap.blue   { background: var(--blue-soft); }
.service-icon-wrap.amber  { background: var(--amber-soft); }
.service-icon-wrap.purple { background: var(--purple-soft); }
.service-icon-wrap.teal   { background: #e0f7f5; }
.service-icon-wrap.rose   { background: #fff1f2; }

.service-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.service-name {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.2px;
}

.service-sub {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
}

.service-arrow {
  font-size: 14px;
  color: var(--text-muted);
}

/* ──────────────────────────────────────────
   RECENT ACTIVITY
────────────────────────────────────────── */
.activity-section {
  padding: 18px 20px 0;
}

.activity-list {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border-radius: var(--radius-sm);
  box-shadow: var(--card-shadow);
  overflow: hidden;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 13px 16px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
  cursor: pointer;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-item:hover {
  background: var(--green-soft);
}

.activity-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
}

.activity-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-primary);
}

.activity-time {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 1px;
  font-weight: 400;
}

.activity-chevron {
  font-size: 12px;
  color: var(--text-muted);
}

/* ──────────────────────────────────────────
   FARMING TIP
────────────────────────────────────────── */
.tip-section {
  padding: 14px 20px 20px;
}

.tip-card {
  background: var(--amber-soft);
  border-left: 3px solid var(--amber);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tip-header {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--amber);
}

.tip-text {
  font-size: 12px;
  color: #78550a;
  line-height: 1.55;
  font-weight: 400;
}

/* ──────────────────────────────────────────
   FLOATING ACTION BUTTON
────────────────────────────────────────── */
.fab {
  position: fixed;
  right: calc(50% - 215px + 16px);
  bottom: 90px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--green-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(26, 92, 42, 0.35);
  cursor: pointer;
  border: none;
  transition: transform 0.18s, box-shadow 0.18s;
  z-index: 300;
}

.fab:hover {
  transform: scale(1.08);
  box-shadow: 0 6px 20px rgba(26, 92, 42, 0.45);
}

/* ──────────────────────────────────────────
   BOTTOM NAV
────────────────────────────────────────── */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 430px;
  background: var(--white);
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 10px 0 16px;
  z-index: 200;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  flex: 1;
}

.nav-item-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  transition: background 0.15s;
}

.nav-item.active .nav-item-icon {
  background: var(--green-soft);
}

.nav-item-lbl {
  font-size: 10px;
  font-weight: 500;
  color: var(--text-muted);
}

.nav-item.active .nav-item-lbl {
  color: var(--green-dark);
  font-weight: 600;
}

/* ──────────────────────────────────────────
   RESPONSIVE
────────────────────────────────────────── */
@media (max-width: 430px) {
  .fab {
    right: 16px;
  }
}
